{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeMantis",
  "version": "0.8.0",
  "identifier": "dev.codemantis.myapp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/pre-build-clean.sh && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeMantis",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": {
      "signingIdentity": "Developer ID Application: HCR-Holding Gmbh (3DNX7TQ9FQ)",
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "files": {
        "Resources/Credits.rtf": "resources/Credits.rtf"
      },
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/templates.json",
      "resources/claude-md/*",
      "resources/user-guide.md"
    ]
  }
}
